if __name__ == "__main__":
    # Create a packet
    pkt = Packet(packet_type=1, content={"msg": "Hello", "id": 745})
    data = pkt.serialize()
    print(f"Serialized data length: {len(data)} bytes")

    # Deserialize the packet
    pkt2 = Packet.deserialize(data)
    print(f"Packet type: {pkt2.header.packet_type}")       # 1
    print(f"Message: {pkt2.payload.content['msg']}")       # Hello
    print(f"ID: {pkt2.payload.content['id']}")             # 745
    
    # Check for extra data beyond the payload (if any)
    if len(data) > PacketHeader.HEADER_SIZE + pkt2.header.payload_length:
        extra = data[PacketHeader.HEADER_SIZE + pkt2.header.payload_length:]
        print(f"Extra bytes: {extra}")
    else:
        print("No extra bytes.")
