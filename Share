# /shared/packet_types.py

import struct
import json
from typing import Dict, Any

class PacketHeader:
    """Defines the header portion of a packet"""
    HEADER_FORMAT = "!II"  # 2 unsigned ints (4 bytes each)
    HEADER_SIZE = struct.calcsize(HEADER_FORMAT)  # = 8 bytes

    def __init__(self, packet_type: int, payload_length: int = 0):
        self.packet_type = packet_type
        self.payload_length = payload_length

    def serialize(self) -> bytes:
        return struct.pack(self.HEADER_FORMAT, self.packet_type, self.payload_length)

    @classmethod
    def deserialize(cls, data: bytes) -> "PacketHeader":
        packet_type, payload_length = struct.unpack(cls.HEADER_FORMAT, data[:cls.HEADER_SIZE])
        return cls(packet_type, payload_length)


class PacketPayload:
    """Defines the payload portion, using JSON for convenience"""
    ENCODING = "utf-8"

    def __init__(self, content: Dict[str, Any]):
        self.content = content

    def serialize(self) -> bytes:
        return json.dumps(self.content).encode(self.ENCODING)

    @classmethod
    def deserialize(cls, data: bytes) -> "PacketPayload":
        content = json.loads(data.decode(cls.ENCODING))
        return cls(content)


class Packet:
    """Complete packet consisting of header + payload"""
    def __init__(self, packet_type: int, content: Dict[str, Any]):
        self.header = None
        self.payload = PacketPayload(content)
        self.header = PacketHeader(packet_type, len(self.payload.serialize()))

    def serialize(self) -> bytes:
        payload_bytes = self.payload.serialize()
        # Update payload_length in header to be accurate
        self.header.payload_length = len(payload_bytes)
        return self.header.serialize() + payload_bytes

    @classmethod
    def deserialize(cls, data: bytes) -> "Packet":
        header = PacketHeader.deserialize(data)
        # Extract exactly the payload portion based on payload_length from header
        payload_start = PacketHeader.HEADER_SIZE
        payload_end = payload_start + header.payload_length
        payload_data = data[payload_start:payload_end]
        
        payload = PacketPayload.deserialize(payload_data)
        packet = cls(header.packet_type, payload.content)
        return packet


